# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/accesspilot?schema=public"

# Default org (for local/dev bootstrap)
DEFAULT_ORG_ID="default-org"

# Auth (choose Clerk or NextAuth)
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="replace_me"
CLERK_SECRET_KEY=""
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=""

# Queue / cache
REDIS_URL="redis://localhost:6379"

# Billing
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""

# Email
RESEND_API_KEY=""
MAIL_FROM="noreply@accesspilot.dev"

# Error monitoring
SENTRY_DSN=""

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
